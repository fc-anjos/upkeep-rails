<% children = comments_by_parent[comment.id] %>

<li class="comments_subtree">
  <%= render "comments/comment", :comment => comment,
    :show_story => depth.zero?,
    :show_tree_lines => true,
    :children => children %>

  <% if depth.positive? %>
    <div class="comment_siblings_tree_line"></div>
  <% end %>

  <ol class="comments">
    <% if children %>
      <%= render partial: "comments/thread_comment",
        collection: children,
        as: :comment,
        locals: { comments_by_parent: comments_by_parent, depth: depth + 1 } %>
    <% end %>
  </ol>
</li>
